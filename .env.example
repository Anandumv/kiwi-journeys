# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Railway provides this automatically as DATABASE_URL)
DATABASE_URL="postgresql://user:password@host:5432/kiwi_journeys"

# ── Authentication ─────────────────────────────────────────────────────────────
# Random secret for signing admin session JWTs — generate with: openssl rand -hex 32
AUTH_SECRET="replace-with-32-byte-random-hex"

# ── Stripe ─────────────────────────────────────────────────────────────────────
# Use sk_test_* keys for staging, sk_live_* for production
STRIPE_SECRET_KEY="sk_test_..."
# Publishable key — safe to expose to the browser
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Webhook signing secret — from the Stripe dashboard → Webhooks → your endpoint
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
# Must be a verified sender domain in Resend. Falls back to onboarding@resend.dev if unset.
BOOKINGS_FROM_EMAIL="bookings@yourdomain.com"

# ── File Storage (Vercel Blob) ─────────────────────────────────────────────────
# Required for persistent image uploads in the admin panel.
# Create a Blob store in your Vercel project → Storage → Blob.
# Without this, uploads are written to the local filesystem and lost on redeploy.
BLOB_READ_WRITE_TOKEN="vercelblob_rw_..."

# ── Cron Security ──────────────────────────────────────────────────────────────
# Secret passed as Bearer token to protect cron endpoints — generate with: openssl rand -hex 32
CRON_SECRET="replace-with-32-byte-random-hex"

# ── Public URLs ────────────────────────────────────────────────────────────────
# Full URL of the deployed site (no trailing slash) — used in sitemap and emails
NEXT_PUBLIC_BASE_URL="https://yourdomain.com"

# ── WhatsApp Notifications (Meta WhatsApp Cloud API) ──────────────────────────
# Required for WhatsApp alerts on new bookings (admin) and booking confirmations (customer).
#
# Setup (one-time):
#   1. Go to developers.facebook.com → My Apps → Create App → Business
#   2. Add "WhatsApp" product → set up a WhatsApp Business phone number
#   3. Copy the Phone Number ID and generate a Permanent Access Token
#
META_WHATSAPP_TOKEN="EAAxxxxxxx..."       # Permanent access token from Meta Business Manager
META_WHATSAPP_PHONE_ID="12345678901234"  # Phone Number ID (not the phone number itself)
#
# WhatsApp number to receive new booking alerts — the tour operator's mobile in E.164 format.
# Falls back to the site phone in SiteSettings if not set.
ADMIN_WHATSAPP="+64XXXXXXXXX"

# ── Optional ───────────────────────────────────────────────────────────────────
# Minutes a seat hold stays active before expiring (default: 10)
RESERVATION_HOLD_MINUTES=10
